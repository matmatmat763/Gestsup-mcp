# Configuration du serveur MCP GestSup
# Copiez ce fichier en .env (ne committez jamais votre vraie clé).

# URL de base de votre instance GestSup (sans /api/v1), HTTPS obligatoire.
GESTSUP_BASE_URL=https://support.exemple.fr

# Clé d'API GestSup (Administration > Paramètres > Connecteurs > API).
GESTSUP_API_KEY=remplacez-par-votre-cle

# Mode d'authentification : "header" (X-API-KEY, défaut) ou "basic".
GESTSUP_AUTH_MODE=header

# Timeout des requêtes en millisecondes (défaut 15000).
#GESTSUP_TIMEOUT_MS=15000

# Identité technicien (tusers.id) : auteur des écritures et « mes tickets ».
# Optionnel en lecture seule ; REQUIS pour les écritures (création, commentaire…).
#GESTSUP_DEFAULT_USER_ID=1

# Kill-switch écriture : "false" pour interdire création/commentaire (lecture seule).
#GESTSUP_ALLOW_WRITES=true

# TEST LOCAL UNIQUEMENT : "true" ignore la vérification du certificat TLS
# (utile avec le stack Docker auto-signé). Ne jamais activer en production.
#GESTSUP_INSECURE_TLS=false

# Clôture conforme : ids des types "incident" (cause obligatoire à la clôture),
# séparés par des virgules. Si non défini, le type est détecté par son nom
# (contenant "incident"). Ex. type 2 = Incident :
#GESTSUP_INCIDENT_TYPE_IDS=2

# --- Documentation Obsidian (optionnel) ---------------------------------------
# Racine du vault Obsidian (dossier contenant les .md). Si défini, les outils de
# documentation (obsidian_*, gestsup_document_ticket) sont activés. Accès par
# fichiers : aucune dépendance à l'app Obsidian ni à un plugin tiers, donc
# compatible avec n'importe quel client MCP (Hermes, etc.).
#OBSIDIAN_VAULT_PATH=/chemin/vers/mon-vault

# Sous-dossier où ranger les notes générées (défaut "KB").
#OBSIDIAN_DOCS_FOLDER=KB

# Kill-switch écriture du vault : "false" = lecture seule des notes.
#OBSIDIAN_ALLOW_WRITES=true

# Score minimal (0-100) pour juger un ticket "documentable" (défaut 60).
#GESTSUP_DOC_QUALITY_THRESHOLD=60
